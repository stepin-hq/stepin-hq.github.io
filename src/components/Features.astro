---
import vrWalkthroughsSrc from '../assets/immersive-vr-walkthroughs.svg?url';
import linkSharingSrc from '../assets/link-based-sharing.svg?url';
import formatSupportSrc from '../assets/format-support.svg?url';
import salesSrc from '../assets/sales-presentations.svg?url';
import arPreviewSrc from '../assets/ar-preview.svg?url';
import multiUserSrc from '../assets/multi-user-sessions.svg?url';
import { useTranslations } from '../i18n';

const locale = Astro.currentLocale ?? 'en';
const t = useTranslations(locale);

const icons = [vrWalkthroughsSrc, linkSharingSrc, formatSupportSrc, salesSrc, arPreviewSrc, multiUserSrc];
const features = t.features.items.map((item, i) => ({ ...item, icon: icons[i] }));
---

<section id="features" class="py-20 lg:py-28 xl:py-36 2xl:py-44">
  <div class="site-container">
    <!-- Header -->
    <div class="mb-12">
      <div class="section-badge w-fit mb-4">
        <span class="w-3 h-3 rounded-full bg-[#A2BCFF] shrink-0"></span>
        <span>{t.features.badge}</span>
      </div>
      <h2 class="font-onest font-bold text-[#EDEDED] text-3xl lg:text-[36px] xl:text-[44px] 2xl:text-[52px]">{t.features.title}</h2>
    </div>

    <!-- Grid — no border-radius on cards, horizontal icon+text layout -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-[16px]">
      {features.map(feature => (
        <div class="bg-[#191C22] flex gap-4 items-start p-6">
          <div class="w-11 h-11 shrink-0 overflow-hidden flex items-center justify-center">
            <img src={feature.icon} alt="" class="w-full h-full object-contain" />
          </div>
          <div class="pt-2">
            <h3 class="font-onest font-bold text-[#A2BCFF] text-[18px] leading-7">
              {feature.title}
              {feature.coming_soon_label && (
                <span class="font-normal text-[#CDD4E4]"> {feature.coming_soon_label}</span>
              )}
            </h3>
            <p class="font-onest text-[#CDD4E4] text-sm leading-relaxed mt-0.5">{feature.body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
