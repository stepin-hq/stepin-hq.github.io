---
import vrWalkthroughsSrc from '../assets/immersive-vr-walkthroughs.svg?url';
import linkSharingSrc from '../assets/link-based-sharing.svg?url';
import formatSupportSrc from '../assets/format-support.svg?url';
import salesSrc from '../assets/sales-presentations.svg?url';
import arPreviewSrc from '../assets/ar-preview.svg?url';
import multiUserSrc from '../assets/multi-user-sessions.svg?url';

const locale = Astro.currentLocale ?? 'en';
const isBg = locale === 'bg';

const features = isBg ? [
  {
    title: 'Потапящи VR разходки',
    body: 'Нека клиентите разходят имоти и дизайни преди да са построени — пълно присъствие, реален мащаб.',
    icon: vrWalkthroughsSrc,
  },
  {
    title: 'Споделяне с линк',
    body: 'Споделете линк, отворете свят. Без изтегляния, без усилие — клиентите разглеждат с един клик.',
    icon: linkSharingSrc,
  },
  {
    title: 'Поддръжка на 3D формати',
    body: 'Работим с .FBX, .OBJ, .glTF, Revit и SketchUp файлове — запазете работния си процес.',
    icon: formatSupportSrc,
  },
  {
    title: 'Търговски презентации',
    body: 'Превърнете разходките в инструменти за затваряне — коментирайте, сравнявайте и получавайте одобрения в реално време.',
    icon: salesSrc,
  },
  {
    title: 'AR преглед',
    body: 'Преглеждайте мебели и пространства в добавена реалност на всеки смартфон.',
    icon: arPreviewSrc,
    comingSoon: true,
    comingSoonLabel: '(Очаква се)',
  },
  {
    title: 'Многопотребителски сесии',
    body: 'Водете клиентите из пространствата заедно — сътрудничете дистанционно в реално VR.',
    icon: multiUserSrc,
  },
] : [
  {
    title: 'Immersive VR Walkthroughs',
    body: "Let clients walk through properties and designs before they're built — full presence, full scale.",
    icon: vrWalkthroughsSrc,
  },
  {
    title: 'Link-Based Sharing',
    body: 'Share a link, open a world. No downloads, no friction — clients explore in one click.',
    icon: linkSharingSrc,
  },
  {
    title: '3D Format Support',
    body: 'We work with .FBX, .OBJ, .glTF, Revit, and SketchUp files — bring your workflow as-is.',
    icon: formatSupportSrc,
  },
  {
    title: 'Sales Presentations',
    body: 'Turn walkthroughs into closing tools — annotate, compare finishes, and get real-time approvals.',
    icon: salesSrc,
  },
  {
    title: 'AR Preview',
    body: 'Preview furniture and spaces in augmented reality on any smartphone.',
    icon: arPreviewSrc,
    comingSoon: true,
    comingSoonLabel: '(Coming Soon)',
  },
  {
    title: 'Multi-User Sessions',
    body: 'Guide clients through spaces together — collaborate remotely in real-time VR.',
    icon: multiUserSrc,
  },
];
---

<section id="features" class="py-20 lg:py-28 xl:py-36 2xl:py-44">
  <div class="site-container">
    <!-- Header -->
    <div class="mb-12">
      <div class="section-badge w-fit mb-4">
        <span class="w-3 h-3 rounded-full bg-[#A2BCFF] shrink-0"></span>
        <span>{isBg ? 'ФУНКЦИИ' : 'FEATURES'}</span>
      </div>
      <h2 class="font-onest font-bold text-[#EDEDED] text-3xl lg:text-[36px] xl:text-[44px] 2xl:text-[52px]">{isBg ? 'Нашата платформа предлага' : 'Our Platform Facilitates'}</h2>
    </div>

    <!-- Grid — no border-radius on cards, horizontal icon+text layout -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-[16px]">
      {features.map(feature => (
        <div class="bg-[#191C22] flex gap-4 items-start p-6">
          <div class="w-11 h-11 shrink-0 overflow-hidden flex items-center justify-center">
            <img src={feature.icon} alt="" class="w-full h-full object-contain" />
          </div>
          <div class="pt-2">
            <h3 class="font-onest font-bold text-[#A2BCFF] text-[18px] leading-7">
              {feature.title}
              {feature.comingSoon && (
                <span class="font-normal text-[#CDD4E4]"> {feature.comingSoonLabel}</span>
              )}
            </h3>
            <p class="font-onest text-[#CDD4E4] text-sm leading-relaxed mt-0.5">{feature.body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
