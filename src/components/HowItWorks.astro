---
import uploadSrc from '../assets/upload-step.svg?url';
import optimizeSrc from '../assets/we-optimize-step.svg?url';
import exploreSrc from '../assets/clients-explore-step.svg?url';
import { useTranslations } from '../i18n';

const locale = Astro.currentLocale ?? 'en';
const t = useTranslations(locale);

const icons = [uploadSrc, optimizeSrc, exploreSrc];
const steps = t.how_it_works.steps.map((step, i) => ({ ...step, icon: icons[i] }));
---

<section id="how-it-works" class="py-20 lg:py-28 xl:py-36 2xl:py-44">
  <div class="site-container">
    <!-- Header -->
    <div class="mb-16 lg:mb-24 text-center">
      <h2 class="font-onest font-bold text-[#EEF3FF] text-3xl lg:text-[36px] xl:text-[44px] 2xl:text-[52px] mb-4 tracking-[-1.2px]">{t.how_it_works.title}</h2>
      <p class="font-onest font-light text-[#CDD4E4] text-base lg:text-lg xl:text-xl max-w-lg xl:max-w-xl mx-auto">
        {t.how_it_works.subtitle}
      </p>
    </div>

    <!-- Steps -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      {steps.map(step => (
        <div class="flex flex-col items-center gap-6 text-center">
          <!-- Icon image -->
          <img src={step.icon} alt={step.icon_alt} class="w-24 h-24 shrink-0" loading="lazy" />
          <div>
            <h3 class="font-onest font-bold text-[#E0E2EB] text-2xl mb-4">
              {step.number} {step.title}
            </h3>
            <p class="font-manrope font-light text-[#C5C6CE] text-base leading-relaxed">{step.body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
