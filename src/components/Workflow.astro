---
import interiorDesignersImg from '../assets/interior-designers.jpg';
import architectsImg from '../assets/architects.jpg';
import realEstateBrokersImg from '../assets/real-estate-brokers.jpg';

const locale = Astro.currentLocale ?? 'en';
const isBg = locale === 'bg';

const audiences = isBg ? [
  {
    id: 'interior-designers',
    heading: 'Интериорни дизайнери',
    body: 'Представете палитри от материали, сценарии за осветление и пространствени решения в пълномащабен VR. Нека клиентите усетят пространството преди да е поръчан и един мостер — итерирайте по-бързо и доставяйте с увереност.',
    image: interiorDesignersImg.src,
    imageAlt: 'Интериорен дизайнер работи с клиент в VR среда',
  },
  {
    id: 'architects',
    heading: 'Архитекти',
    body: 'Комуникирайте обемите, пространствения поток и дизайнерската концепция с изключителна яснота. Разходете заинтересованите страни из визията си в мащаб 1:1 — ускорете одобренията и намалете скъпоструващите ревизии.',
    image: architectsImg.src,
    imageAlt: 'Архитект представя VR разходка на сграда',
  },
  {
    id: 'real-estate',
    heading: 'Брокери на имоти',
    body: 'Продавайте имоти преди да са построени. Предложете на отдалечени купувачи потапящи обиколки, представете проекти на зелено и се откроявайте на конкурентния пазар с презентации, които затварят сделки.',
    image: realEstateBrokersImg.src,
    imageAlt: 'Брокер показва VR обиколка на имот на клиенти',
  },
] : [
  {
    id: 'interior-designers',
    heading: 'Interior Designers',
    body: 'Present material palettes, lighting scenarios, and spatial layouts in full-scale VR. Let clients feel the space before a single swatch is ordered — iterate faster, align expectations, and deliver with confidence.',
    image: interiorDesignersImg.src,
    imageAlt: 'Interior designer working with a client in a VR environment',
  },
  {
    id: 'architects',
    heading: 'Architects',
    body: 'Communicate massing, spatial flow, and design intent with unmatched clarity. Walk stakeholders through your vision at 1:1 scale — accelerate approvals and reduce costly revisions.',
    image: architectsImg.src,
    imageAlt: 'Architect presenting a building walkthrough in VR',
  },
  {
    id: 'real-estate',
    heading: 'Real Estate Brokers',
    body: "Sell properties before they're built. Give remote buyers immersive tours, showcase off-plan developments, and stand out in competitive markets with presentations that close.",
    image: realEstateBrokersImg.src,
    imageAlt: 'Real estate broker showing a VR property tour to clients',
  },
];
---

<section class="py-20 lg:py-28 xl:py-36 2xl:py-44">
  <div class="site-container">
    <!-- Header -->
    <div class="mb-10">
      <div class="section-badge w-fit mb-2">
        <span class="w-3 h-3 rounded-full bg-[#A2BCFF] shrink-0"></span>
        <span>{isBg ? 'ПРИЛОЖЕНИЕ' : 'APPLICATION'}</span>
      </div>
      <h2 class="font-onest font-bold text-[#EEF3FF] text-3xl lg:text-[36px] xl:text-[44px] 2xl:text-[52px] mb-3">{isBg ? 'Създадена за вашия процес' : 'Built for your workflow'}</h2>
      <p class="font-onest text-[#CDD4E4] text-sm max-w-md">{isBg ? 'Вижте как STEP IN се адаптира към специалистите, които имат най-голяма нужда от него.' : 'See how STEP IN APP adapts to the professionals who need it most.'}</p>
    </div>

    <!-- Desktop grid -->
    <div class="hidden md:grid md:grid-cols-3 gap-12">
      {audiences.map(audience => (
        <div class="flex flex-col gap-6">
          <div class="w-full aspect-[4/3] overflow-hidden rounded-[4px]">
            <img
              src={audience.image}
              alt={audience.imageAlt}
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <div class="flex flex-col gap-3">
            <h3 class="font-onest font-bold text-[#A2BCFF] text-2xl">{audience.heading}</h3>
            <p class="font-onest text-[#CDD4E4] text-base leading-relaxed">{audience.body}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Mobile: stacked -->
    <div class="md:hidden flex flex-col gap-10">
      {audiences.map(audience => (
        <div class="flex flex-col gap-5">
          <div class="w-full aspect-[4/3] overflow-hidden rounded-[4px]">
            <img
              src={audience.image}
              alt={audience.imageAlt}
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <div class="flex flex-col gap-2 items-center text-center">
            <h3 class="font-onest font-bold text-[#A2BCFF] text-[22px]">{audience.heading}</h3>
            <p class="font-onest text-[#CDD4E4] text-base leading-relaxed">{audience.body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
