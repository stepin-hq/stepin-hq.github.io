        </g>
      </mask>
    </defs>
  </svg>

  <!-- Intro layer: dark bg + grid — both clipped to the area OUTSIDE the headset hole -->
  <div id="gi-intro-layer"
       style="position:fixed;inset:0;z-index:200;pointer-events:none;mask:url(#gi-mask);">
    <!-- Dark background -->
    <div style="position:absolute;inset:0;background:#080808;"></div>
    <!-- Perspective grid -->
    <div id="gi-grid-host" aria-hidden="true" style="position:absolute;inset:0;">
      <div class="gi-grid-stage">
        <div id="gi-grid-plane" class="gi-grid-plane"></div>
      </div>
      <div class="gi-grid-fade"></div>
    </div>
  </div>

  <Header theme="dark" />
  <main>
    <Hero />
    <WhatIsStepin />
    <Workflow />
    <Features />
    <HowItWorks />
    <ContactCTA />
  </main>
  <Footer theme="dark" />
</BaseLayout>

<style is:global>
  body[data-theme="gray"] .grid-host {
    display: none !important;
  }
  body[data-theme="gray"] .hero-content {
    opacity: 0;
  }

  /* ── Skip-intro: hide overlay synchronously on hard refresh (repeat load) ── */
  html.gi-skip-intro #gi-intro-layer { display: none !important; }
  html.gi-skip-intro .hero-content   { opacity: 1 !important; }

  /* ── Intro grid ──────────────────────────────────────────────────────────── */
  .gi-grid-stage {
    position: absolute;
    inset: 0;
    perspective: 600px;
    perspective-origin: 50% 0%;
  }

  .gi-grid-plane {
    position: absolute;
    bottom: -10%;
    left: -60%;
    right: -60%;
    height: 130%;
    background-image:
      linear-gradient(rgba(162, 188, 255, 0.15) 1px, transparent 1px),
      linear-gradient(90deg, rgba(162, 188, 255, 0.15) 1px, transparent 1px);
    background-size: 80px 80px;
    transform-origin: bottom center;
    opacity: 0;
    transform: rotateX(76deg) scale(1);
  }

  .gi-grid-plane.is-animating {
    animation: giGridReveal 2s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  @keyframes giGridReveal {
    0%   { opacity: 0; transform: rotateX(4deg) scale(4); }
    8%   { opacity: 1; transform: rotateX(6deg) scale(3.6); }
    100% { opacity: 1; transform: rotateX(76deg) scale(1); }
  }

  .gi-grid-fade {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      #080808 0%,
      rgba(8, 8, 8, 0.55) 28%,
      transparent 60%,
      rgba(8, 8, 8, 0.1) 100%
    );
  }
</style>

<script>
  function runIntro() {
    const introLayer = document.getElementById('gi-intro-layer') as HTMLElement | null;
    const content    = document.querySelector<HTMLElement>('.hero-content');

    // Skip on language switches and back-navigation — intro already played
    if (sessionStorage.getItem('stepin-intro-played')) {
      introLayer?.remove();
      document.getElementById('gi-defs')?.remove();
      if (content) content.style.opacity = '1';
      return;
    }

    const hole      = document.getElementById('gi-hole') as SVGGElement | null;
    const gridHost  = document.getElementById('gi-grid-host') as HTMLElement | null;
    const gridPlane = document.getElementById('gi-grid-plane') as HTMLElement | null;

    if (!introLayer || !hole || !gridHost || !gridPlane) return;

    const HW = 1280, HH = 702;
    const cx = window.innerWidth  / 2;
    const cy = window.innerHeight / 2;
    const MAX_SCALE     = Math.ceil(Math.max(window.innerWidth / HW, window.innerHeight / HH)) * 2.2;
    const INITIAL_SCALE = (0.35 * window.innerWidth) / HW;

    function applyScale(s: number) {
      const t = `translate(${cx - (HW / 2) * s} ${cy - (HH / 2) * s}) scale(${s})`;
      hole!.setAttribute('transform', t);
    }

    function easeInOutCubic(t: number) {
      return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
    }

    function easeInCubic(t: number) {
      return t * t * t;
    }

    // Headset hole at initial size — mask clips intro layer to outside-headset only
    applyScale(INITIAL_SCALE);
    if (content) content.style.opacity = '0';

    // Grid animates — visible only in the dark area around the headset
    gridPlane.classList.add('is-animating');

    // Headset pulse begins at 1400ms — grid fades simultaneously
    const HEADSET_START_DELAY = 1400;
    const GRID_FADE_DURATION  = 600;

    const T_PULSE1  = 400;
    const T_PULSE2  = 700;
    const T_EXPAND  = 1900;
    const T_MID     = (T_PULSE2 + T_EXPAND) / 2;
    const T_FADEOUT = 2500;

    setTimeout(() => {
      gridHost.style.transition = `opacity ${GRID_FADE_DURATION}ms ease`;
      gridHost.style.opacity = '0';
      setTimeout(() => { gridHost.style.display = 'none'; }, GRID_FADE_DURATION);

      let startTime: number | null = null;

      function frame(now: number) {
        if (!startTime) startTime = now;
        const e = now - startTime;

        if (e < T_PULSE1) {
          applyScale(INITIAL_SCALE * (1 + 0.18 * easeInOutCubic(e / T_PULSE1)));
        } else if (e < T_PULSE2) {
          applyScale(INITIAL_SCALE * (1.18 - 0.18 * easeInOutCubic((e - T_PULSE1) / (T_PULSE2 - T_PULSE1))));
        } else if (e < T_EXPAND) {
          const t = (e - T_PULSE2) / (T_EXPAND - T_PULSE2);
          applyScale(INITIAL_SCALE + (MAX_SCALE - INITIAL_SCALE) * easeInCubic(t));
          if (content && e >= T_MID) {
            content.style.opacity = String(easeInOutCubic((e - T_MID) / (T_EXPAND - T_MID)));
          }
        } else if (e < T_FADEOUT) {
          applyScale(MAX_SCALE);
          if (content) content.style.opacity = '1';
          introLayer!.style.opacity = String(1 - (e - T_EXPAND) / (T_FADEOUT - T_EXPAND));
        } else {
          if (content) content.style.opacity = '1';
          sessionStorage.setItem('stepin-intro-played', '1');
          introLayer!.remove();
          document.getElementById('gi-defs')?.remove();
          return;
        }

        requestAnimationFrame(frame);
      }

      requestAnimationFrame(frame);
    }, HEADSET_START_DELAY);
  }

  document.addEventListener('astro:page-load', runIntro);
</script>
